# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# App Configuration
NEXT_PUBLIC_APP_NAME=Bucr Vendor Portal
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Mapbox — PUBLIC scoped token (map display only, Styles:Read scope).
# Geocoding calls go through the BUCR backend (/api/geocode) — never from the browser directly.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_public_mapbox_token_here

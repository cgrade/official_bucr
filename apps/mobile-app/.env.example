# API Configuration
# Use your machine LAN IP so Expo Go on phone can reach backend.
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.183:3000
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000

# Optional: EAS project UUID from `eas init` / expo.dev (required for reliable Expo push tokens)
# EXPO_PUBLIC_PROJECT_ID=

# Mapbox — PUBLIC scoped token (map display only, Styles:Read scope only).
# Geocoding is server-side: the backend uses MAPBOX_ACCESS_TOKEN (never this one).
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_mapbox_token_here

# Sentry crash/error reporting (optional — leave blank to disable). Only reports
# from non-dev builds. For source-map upload at EAS build time also set
# SENTRY_AUTH_TOKEN and the org/project in app.json's @sentry/react-native plugin.
EXPO_PUBLIC_SENTRY_DSN=

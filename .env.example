# Database
DATABASE_URL="postgresql://username:password@localhost:5432/bucr?schema=public"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-min-32-characters"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-characters"

# Paystack
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@bucr.ng"

# Termii (SMS)
TERMII_API_KEY="your-termii-api-key"
TERMII_SENDER_ID="Bucr"

# Maps / Geocoding (REQUIRED — branch geocoding + discovery maps)
MAPBOX_ACCESS_TOKEN="pk.xxxxxxxxxxxxxxxxxxxx"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Bucr"

# ─────────────────────────────────────────────────────────────────────────────
# Economics — single source of truth is src/lib/config/economics.ts. These are
# env OVERRIDES for the tunable levers (keys match the constant names). NOTE:
# 1 credit = ₦10 is LOCKED in code (not env-tunable). Defaults shown.
# ─────────────────────────────────────────────────────────────────────────────
CREDIT_SPREAD=0.06
CREDIT_EXPIRY_DAYS=90
EXPIRY_REMINDER_DAYS=30
SHOWUP_BONUS_PCT=0.03
NOSHOW_FORFEIT_PCT=0.40
NOSHOW_VENDOR_PCT=0.30
GIFT_FEE_PCT=0.08
SUBSCRIPTION_PRO_NGN=30000
SUBSCRIPTION_ELITE_NGN=85000

# Cancellation refunds (fractions / hours)
CANCEL_FULL_REFUND_HOURS=24
CANCEL_PARTIAL_REFUND_HOURS=12
CANCEL_PARTIAL_REFUND_PCT=0.50
# When the VENDOR cancels: guest gets 100% + this bonus, PAID BY THE VENDOR from their
# marketing wallet (vendor must hold ≥ this fraction of the deposit in credits to cancel).
VENDOR_CANCEL_BONUS_PCT=0.10

# Per-cover success fee (NGN per SEATED HEAD — total = base × tier multiplier × partySize)
COVER_FEE_FINE_DINING=1500
COVER_FEE_UPSCALE_CASUAL=1500
COVER_FEE_LOUNGE=1500
COVER_FEE_CASUAL=1500
COVER_MULTIPLIER_BASIC=1.0
COVER_MULTIPLIER_PRO=0.5
COVER_MULTIPLIER_ELITE=0.0

# Featured (ad) placement
FEATURED_CAROUSEL_MAX=5
FEATURED_IMPRESSION_DEDUP_MINUTES=30

# Multi-currency DISPLAY (off for the Nigeria launch; flip per market post-counsel)
MULTI_CURRENCY_DISPLAY_ENABLED=false
FX_CACHE_TTL_SECONDS=86400

# LEGAL GATE — keep false until a licensed partner + counsel sign-off
VENDOR_WITHDRAWAL_ENABLED=false

# Security
BCRYPT_SALT_ROUNDS=12

# Paystack Webhook Secret
PAYSTACK_WEBHOOK_SECRET="your-webhook-secret"

# Redis
REDIS_URL="redis://localhost:6379"

# Cron Job Secret
CRON_SECRET="your-cron-secret-min-32-characters"

# Portal URLs (for CORS)
ADMIN_PORTAL_URL="http://localhost:3002"
VENDOR_PORTAL_URL="http://localhost:3001"

# Error Monitoring
SENTRY_DSN=""

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  phone               String?             @unique
  passwordHash        String              @map("password_hash")
  name                String
  avatar              String?
  role                UserRole            @default(user)
  status              UserStatus          @default(active)
  suspendedReason     String?             @map("suspended_reason")
  creditsBalance      Int                 @default(0) @map("credits_balance")
  dietaryRestrictions String[]            @default([]) @map("dietary_restrictions")
  seatingPreferences  String?             @map("seating_preferences")
  specialOccasions    Json?               @map("special_occasions")
  referralCode        String?             @unique @map("referral_code")
  referredBy          String?             @map("referred_by")
  pushToken                String?             @map("push_token")
  notificationPreferences  Json?               @map("notification_preferences")
  emailVerifiedAt          DateTime?           @map("email_verified_at")
  phoneVerifiedAt     DateTime?           @map("phone_verified_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  deletedAt           DateTime?           @map("deleted_at")
  creditTransactions  CreditTransaction[]
  favorites           Favorite[]
  guestProfiles       GuestProfile[]
  sentInvitations     Invitation[]        @relation("InvitationSender")
  reservations        Reservation[]
  reviews             Review[]
  orders              TakeoutOrder[]
  waitlistEntries     Waitlist[]
  eventTickets        EventTicket[]
  eventBundles        EventBundle[]
  notifications       Notification[]
  sentGifts           Gift[]              @relation("GiftSender")
  receivedGifts       Gift[]              @relation("GiftRecipient")

  @@map("users")
}

model Admin {
  id                String           @id @default(uuid())
  email             String           @unique
  passwordHash      String           @map("password_hash")
  name              String
  role              String           @default("sub_admin")
  permissions       String[]         @default([])
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")
  verifiedDocuments VendorDocument[] @relation("DocumentVerifier")

  @@map("admins")
}

model Vendor {
  id                    String             @id @default(uuid())
  ownerId               String             @map("owner_id")
  businessName          String             @map("business_name")
  slug                  String             @unique
  description           String?
  logo                  String?
  businessType          BusinessType       @default(restaurant) @map("business_type")
  venueType             VenueType          @default(upscale_casual) @map("venue_type")
  // Diner-facing price level (OpenTable/Google standard): 1=₦ … 4=₦₦₦₦
  priceLevel            Int                @default(2) @map("price_level")
  cuisineTypes          String[]           @default([]) @map("cuisine_types")
  subscriptionTier      SubscriptionTier   @default(basic) @map("subscription_tier")
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")
  verificationStatus    VerificationStatus @default(pending) @map("verification_status")
  bankName              String?            @map("bank_name")
  bankAccountNumber     String?            @map("bank_account_number")
  bankAccountName       String?            @map("bank_account_name")
  paystackLink          String?            @map("paystack_link")
  deliveryEnabled       Boolean            @default(false) @map("delivery_enabled")
  deliveryFeeType       DeliveryFeeType?   @map("delivery_fee_type")
  deliveryFlatFee       Int?               @map("delivery_flat_fee")
  deliveryZones         Json?              @map("delivery_zones")
  minDeliveryOrder      Int?               @map("min_delivery_order")
  email                 String
  phone                 String
  website               String?
  totalBookings         Int                @default(0) @map("total_bookings")
  noShowCount           Int                @default(0) @map("no_show_count")
  averageRating         Float?             @map("average_rating")
  totalReviews          Int                @default(0) @map("total_reviews")
  // Reliability score (Phase 10)
  reliabilityScore      Float?             @map("reliability_score")
  bookWithConfidence    Boolean            @default(false) @map("book_with_confidence")
  badgeQualifyingSince  DateTime?          @map("badge_qualifying_since")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  deletedAt             DateTime?          @map("deleted_at")
  featuredAt            DateTime?          @map("featured_at")
  featuredUntil         DateTime?          @map("featured_until")
  isFeatured            Boolean            @default(false) @map("is_featured")
  // Display settings
  showExperiences       Boolean            @default(true) @map("show_experiences")
  showSpecialOffers     Boolean            @default(true) @map("show_special_offers")
  showAchievements      Boolean            @default(true) @map("show_achievements")
  showGallery           Boolean            @default(true) @map("show_gallery")
  showReviews           Boolean            @default(true) @map("show_reviews")
  showMenu              Boolean            @default(true) @map("show_menu")
  promoMessage          String?            @map("promo_message")
  promoEnabled          Boolean            @default(false) @map("promo_enabled")
  // Vendor-configurable deposit — overrides global ECONOMICS tiers when set
  // null = use global tier table; any positive int = flat credits for all reservations
  customDepositCredits  Int?               @map("custom_deposit_credits")
  // Vendor notification preferences (newReservations, cancellations, newOrders, newReviews, weeklyReports)
  notificationPreferences Json?            @map("notification_preferences")
  achievements          Achievement[]
  experiences           Experience[]
  specialOffers         SpecialOffer[]
  favorites             Favorite[]
  galleryImages         GalleryImage[]
  guestProfiles         GuestProfile[]
  menuCategories        MenuCategory[]
  menus                 Menu[]
  reservations          Reservation[]
  reviews               Review[]
  orders                TakeoutOrder[]
  branches              VendorBranch[]
  documents             VendorDocument[]
  wallet                VendorWallet?
  waitlistEntries       Waitlist[]
  featuredSpots         FeaturedSpot[]
  events                Event[]
  coverCharges          CoverCharge[]
  platformRevenues      PlatformRevenue[]

  @@index([verificationStatus, deletedAt])
  @@index([slug])
  @@index([venueType])
  @@index([priceLevel])
  @@map("vendors")
}

model VendorBranch {
  id              String         @id @default(uuid())
  vendorId        String         @map("vendor_id")
  name            String
  address         String
  city            String
  state           String
  country         String         @default("Nigeria")
  latitude        Float?
  longitude       Float?
  operatingHours  Json?          @map("operating_hours")
  phone           String?
  email           String?
  isActive        Boolean        @default(true) @map("is_active")
  isMainBranch    Boolean        @default(false) @map("is_main_branch")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  reservations    Reservation[]
  orders          TakeoutOrder[]
  vendor          Vendor         @relation(fields: [vendorId], references: [id])
  waitlistEntries Waitlist[]

  @@index([vendorId])
  @@index([country, city])
  @@map("vendor_branches")
}

model VendorDocument {
  id              String             @id @default(uuid())
  vendorId        String             @map("vendor_id")
  type            DocumentType
  fileUrl         String             @map("file_url")
  fileName        String?            @map("file_name")
  status          VerificationStatus @default(pending)
  isRequired      Boolean            @default(true) @map("is_required")
  reviewedById    String?            @map("reviewed_by_id")
  reviewedAt      DateTime?          @map("reviewed_at")
  rejectionReason String?            @map("rejection_reason")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  reviewedBy      Admin?             @relation("DocumentVerifier", fields: [reviewedById], references: [id])
  vendor          Vendor             @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, type])
  @@map("vendor_documents")
}

model MenuCategory {
  id          String   @id @default(uuid())
  vendorId    String   @map("vendor_id")
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  items       Menu[]

  @@index([vendorId])
  @@map("menu_categories")
}

model Menu {
  id                  String        @id @default(uuid())
  vendorId            String        @map("vendor_id")
  categoryId          String?       @map("category_id")
  name                String
  description         String?
  price               Int           @default(0)
  image               String?
  isAvailable         Boolean       @default(true) @map("is_available")
  availableForDineIn  Boolean       @default(true) @map("available_for_dine_in")
  availableForTakeout Boolean       @default(true) @map("available_for_takeout")
  // Temporary "86" — item is unavailable until this timestamp (null = permanent toggle controls)
  unavailableUntil    DateTime?     @map("unavailable_until")
  sortOrder           Int           @default(0) @map("sort_order")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  deletedAt           DateTime?     @map("deleted_at")
  category            MenuCategory? @relation(fields: [categoryId], references: [id])
  vendor              Vendor        @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([isAvailable])
  @@index([unavailableUntil])
  @@map("menus")
}

model GalleryImage {
  id         String   @id @default(uuid())
  vendorId   String   @map("vendor_id")
  url        String
  caption    String?
  category   String?
  isFeatured Boolean  @default(false) @map("is_featured")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  vendor     Vendor   @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@map("gallery_images")
}

model Reservation {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  vendorId           String            @map("vendor_id")
  branchId           String?           @map("branch_id")
  experienceId       String?           @map("experience_id")
  reference          String            @unique
  date               DateTime
  time               String
  partySize          Int               @map("party_size")
  specialRequests    String?           @map("special_requests")
  occasion           String?
  creditsDeposited   Int               @map("credits_deposited")
  creditsRefunded    Int               @default(0) @map("credits_refunded")
  bonusCredits       Int               @default(0) @map("bonus_credits")
  status             ReservationStatus @default(pending)
  qrCode             String?           @map("qr_code")
  pin                String?
  checkedInAt        DateTime?         @map("checked_in_at")
  cancelledAt        DateTime?         @map("cancelled_at")
  cancelledBy        String?           @map("cancelled_by")
  cancellationReason String?           @map("cancellation_reason")
  idempotencyKey     String?           @map("idempotency_key") // prevents double-booking on network retry
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  invitations        Invitation[]
  branch             VendorBranch?     @relation(fields: [branchId], references: [id])
  experience         Experience?       @relation(fields: [experienceId], references: [id])
  user               User              @relation(fields: [userId], references: [id])
  vendor             Vendor            @relation(fields: [vendorId], references: [id])
  review             Review?
  eventBundle        EventBundle?
  coverCharge        CoverCharge?

  @@index([userId])
  @@index([vendorId])
  @@index([date])
  @@index([status])
  @@index([date, status])
  @@index([userId, status])
  @@index([vendorId, date, status])
  @@index([reference])
  @@index([idempotencyKey, userId])
  @@map("reservations")
}

model Invitation {
  id             String           @id @default(uuid())
  reservationId  String           @map("reservation_id")
  inviterId      String           @map("inviter_id")
  inviteeName    String           @map("invitee_name")
  inviteeContact String           @map("invitee_contact")
  status         InvitationStatus @default(pending)
  respondedAt    DateTime?        @map("responded_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  inviter        User             @relation("InvitationSender", fields: [inviterId], references: [id])
  reservation    Reservation      @relation(fields: [reservationId], references: [id])

  @@index([reservationId])
  @@map("invitations")
}

model Waitlist {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  vendorId       String         @map("vendor_id")
  branchId       String?        @map("branch_id")
  desiredDate    DateTime       @map("desired_date")
  desiredTime    String         @map("desired_time")
  partySize      Int            @map("party_size")
  status         WaitlistStatus @default(waiting)
  notifiedAt     DateTime?      @map("notified_at")
  claimExpiresAt DateTime?      @map("claim_expires_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  branch         VendorBranch?  @relation(fields: [branchId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  vendor         Vendor         @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([userId])
  @@index([status])
  @@map("waitlist")
}

model TakeoutOrder {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  vendorId           String        @map("vendor_id")
  branchId           String?       @map("branch_id")
  reference          String        @unique
  orderType          OrderType     @map("order_type")
  items              Json
  subtotal           Int
  deliveryFee        Int           @default(0) @map("delivery_fee")
  total              Int
  deliveryAddress    String?       @map("delivery_address")
  deliveryCity       String?       @map("delivery_city")
  deliveryNotes      String?       @map("delivery_notes")
  status             OrderStatus   @default(pending)
  scheduledTime      DateTime?     @map("scheduled_time")
  paymentConfirmed   Boolean       @default(false) @map("payment_confirmed")
  paymentConfirmedAt DateTime?     @map("payment_confirmed_at")
  completedAt        DateTime?     @map("completed_at")
  cancelledAt        DateTime?     @map("cancelled_at")
  cancelledBy        String?       @map("cancelled_by")
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  review             Review?
  branch             VendorBranch? @relation(fields: [branchId], references: [id])
  user               User          @relation(fields: [userId], references: [id])
  vendor             Vendor        @relation(fields: [vendorId], references: [id])

  @@index([userId])
  @@index([vendorId])
  @@index([status])
  @@map("takeout_orders")
}

model VendorWallet {
  id                String                    @id @default(uuid())
  vendorId          String                    @unique @map("vendor_id")
  balance           Int                       @default(0)
  totalEarned       Int                       @default(0) @map("total_earned")
  totalSpent        Int                       @default(0) @map("total_spent")
  totalWithdrawn    Int                       @default(0) @map("total_withdrawn")
  pendingWithdrawal Int                       @default(0) @map("pending_withdrawal")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  transactions      VendorCreditTransaction[]
  vendor            Vendor                    @relation(fields: [vendorId], references: [id])

  @@map("vendor_wallets")
}

model VendorCreditTransaction {
  id               String           @id @default(uuid())
  walletId         String           @map("wallet_id")
  type             VendorCreditType
  amount           Int
  balanceAfter     Int              @map("balance_after")
  referenceType    String?          @map("reference_type")
  referenceId      String?          @map("reference_id")
  bankName         String?          @map("bank_name")
  bankAccount      String?          @map("bank_account")
  withdrawalStatus String?          @map("withdrawal_status")
  description      String?
  createdAt        DateTime         @default(now()) @map("created_at")
  wallet           VendorWallet     @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("vendor_credit_transactions")
}

model CreditTransaction {
  id                String                @id @default(uuid())
  userId            String                @map("user_id")
  type              CreditTransactionType
  status            CreditStatus          @default(active)
  amount            Int
  remainingAmount   Int?                  @map("remaining_amount")
  balanceAfter      Int                   @map("balance_after")
  referenceType     String?               @map("reference_type")
  referenceId       String?               @map("reference_id")
  paystackReference String?               @map("paystack_reference")
  amountPaidKobo    Int?                  @map("amount_paid_kobo")
  expiresAt         DateTime?             @map("expires_at")
  expiredAt         DateTime?             @map("expired_at")
  description       String?
  createdAt         DateTime              @default(now()) @map("created_at")
  user              User                  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@index([userId, createdAt])
  @@index([expiresAt, expiredAt])
  @@map("credit_transactions")
}

model Review {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  vendorId       String        @map("vendor_id")
  reservationId  String?       @unique @map("reservation_id")
  orderId        String?       @unique @map("order_id")
  rating         Int
  text           String?
  creditsEarned  Int           @default(0) @map("credits_earned")
  vendorResponse String?       @map("vendor_response")
  respondedAt    DateTime?     @map("responded_at")
  isVisible      Boolean       @default(true) @map("is_visible")
  isReported     Boolean       @default(false) @map("is_reported")
  reportReason   String?       @map("report_reason")
  reportedAt     DateTime?     @map("reported_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  order          TakeoutOrder? @relation(fields: [orderId], references: [id])
  reservation    Reservation?  @relation(fields: [reservationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  vendor         Vendor        @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model Experience {
  id              String        @id @default(uuid())
  vendorId        String        @map("vendor_id")
  title           String
  description     String?
  type            String
  creditsRequired Int           @map("credits_required")
  capacity        Int?
  duration        Int?
  availableDates  Json?         @map("available_dates")
  availableDays   Int[]         @default([]) @map("available_days")
  startTime       String?       @map("start_time")
  endTime         String?       @map("end_time")
  images          String[]      @default([])
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  vendor          Vendor        @relation(fields: [vendorId], references: [id])
  reservations    Reservation[]

  @@index([vendorId])
  @@index([isActive])
  @@map("experiences")
}

model Achievement {
  id          String   @id @default(uuid())
  vendorId    String   @map("vendor_id")
  title       String
  description String?
  icon        String?
  badgeType   String?  @map("badge_type")
  earnedAt    DateTime @default(now()) @map("earned_at")
  vendor      Vendor   @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@map("achievements")
}

model SpecialOffer {
  id           String    @id @default(uuid())
  vendorId     String    @map("vendor_id")
  title        String
  description  String?
  image        String?
  videoUrl     String?   @map("video_url")
  discountType String?   @map("discount_type")
  discountValue Int?     @map("discount_value")
  terms        String?
  validFrom    DateTime? @map("valid_from")
  validUntil   DateTime? @map("valid_until")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  vendor       Vendor    @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([isActive])
  @@map("special_offers")
}

model GuestProfile {
  id          String    @id @default(uuid())
  vendorId    String    @map("vendor_id")
  userId      String    @map("user_id")
  visitCount  Int       @default(0) @map("visit_count")
  noShowCount Int       @default(0) @map("no_show_count")
  totalSpend  Int       @default(0) @map("total_spend")
  lastVisit   DateTime? @map("last_visit")
  notes       String?
  tags        String[]  @default([])
  preferences Json?
  isVip       Boolean   @default(false) @map("is_vip")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id])
  vendor      Vendor    @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, userId])
  @@map("guest_profiles")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  vendorId  String   @map("vendor_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
  vendor    Vendor   @relation(fields: [vendorId], references: [id])

  @@unique([userId, vendorId])
  @@index([userId])
  @@map("favorites")
}

model Payment {
  id                String          @id @default(uuid())
  userId            String?         @map("user_id")
  vendorId          String?         @map("vendor_id")
  channel           PaymentChannel?
  purpose           PaymentPurpose
  status            PaymentStatus   @default(pending)
  amountKobo        Int             @map("amount_kobo")
  currency          String          @default("NGN")
  reference         String          @unique
  providerReference String?         @map("provider_reference")
  metadata          Json?
  bankName          String?         @map("bank_name")
  accountNumber     String?         @map("account_number")
  accountName       String?         @map("account_name")
  paidAt            DateTime?       @map("paid_at")
  expiresAt         DateTime?       @map("expires_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@index([vendorId])
  @@index([reference])
  @@index([status])
  @@map("payments")
}

model VendorSubscription {
  id             String           @id @default(uuid())
  vendorId       String           @map("vendor_id")
  tier           SubscriptionTier
  status         String           @default("active")
  amountPaidKobo Int              @map("amount_paid_kobo")
  paymentId      String?          @map("payment_id")
  startsAt       DateTime         @map("starts_at")
  expiresAt      DateTime         @map("expires_at")
  autoRenew      Boolean          @default(false) @map("auto_renew")
  cancelledAt    DateTime?        @map("cancelled_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@index([vendorId])
  @@index([status])
  @@index([expiresAt, status])
  @@map("vendor_subscriptions")
}

// Per-cover success fee accrued on each check-in
model CoverCharge {
  id           String   @id @default(uuid())
  vendorId     String   @map("vendor_id")
  reservationId String  @unique @map("reservation_id")
  partySize    Int      @map("party_size")
  feeCharged   Int      @map("fee_charged")         // NGN
  venueType    String   @map("venue_type")
  tierAtTime   String   @map("tier_at_time")
  billingMonth String   @map("billing_month")       // "YYYY-MM"
  status       String   @default("accrued")          // accrued | invoiced | paid
  invoicedAt   DateTime? @map("invoiced_at")
  paidAt       DateTime? @map("paid_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  vendor       Vendor   @relation(fields: [vendorId], references: [id])
  reservation  Reservation @relation(fields: [reservationId], references: [id])

  @@index([vendorId])
  @@index([billingMonth])
  @@index([status])
  @@index([vendorId, billingMonth, status])
  @@map("cover_charges")
}

// Platform revenue ledger — one row per recognised revenue event
model PlatformRevenue {
  id            String   @id @default(uuid())
  type          PlatformRevenueType
  amountNgn     Int      @map("amount_ngn")
  amountCredits Int?     @map("amount_credits")
  sourceType    String   @map("source_type")
  sourceId      String   @map("source_id")
  vendorId      String?  @map("vendor_id")
  userId        String?  @map("user_id")
  billingMonth  String   @map("billing_month")  // "YYYY-MM"
  recognizedAt  DateTime @default(now()) @map("recognized_at")
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])

  @@index([type])
  @@index([billingMonth])
  @@index([vendorId])
  @@index([type, billingMonth])
  @@map("platform_revenue")
}

// User-to-user credit gifting
model Gift {
  id               String     @id @default(uuid())
  senderId         String     @map("sender_id")
  recipientUserId  String?    @map("recipient_user_id")
  recipientEmail   String?    @map("recipient_email")
  recipientPhone   String?    @map("recipient_phone")
  creditAmount     Int        @map("credit_amount")
  feeCredits       Int        @map("fee_credits")
  message          String?
  status           GiftStatus @default(pending)
  expiresAt        DateTime   @map("expires_at")
  claimedAt        DateTime?  @map("claimed_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  sender           User       @relation("GiftSender", fields: [senderId], references: [id])
  recipientUser    User?      @relation("GiftRecipient", fields: [recipientUserId], references: [id])

  @@index([senderId])
  @@index([recipientUserId])
  @@index([status])
  @@index([expiresAt])
  @@map("gifts")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  channel   String
  title     String
  body      String
  data      Json?
  status    String    @default("pending")
  sentAt    DateTime? @map("sent_at")
  readAt    DateTime? @map("read_at")
  error     String?
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([status])
  @@map("notifications")
}

model ReportHistory {
  id          String   @id @default(uuid())
  type        String
  generatedBy String   @map("generated_by")
  adminId     String?  @map("admin_id")
  parameters  Json?
  status      String   @default("completed")
  fileUrl     String?  @map("file_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([type])
  @@index([createdAt])
  @@map("report_history")
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  type      String
  otp       String?
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, type])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// ============================================================================
// EVENTS
// ============================================================================

enum EventCategory {
  dining
  concert
  wedding
  corporate
  festival
  other
}

enum EventStatus {
  draft
  published
  cancelled
  completed
}

enum EventTicketStatus {
  pending
  confirmed
  checked_in
  cancelled
  no_show
}

enum BundleStatus {
  pending
  confirmed
  completed
  cancelled
}

model Event {
  id             String        @id @default(uuid())
  vendorId       String        @map("vendor_id")
  title          String
  description    String?
  date           DateTime
  endDate        DateTime?     @map("end_date")
  location       String
  address        String?
  city           String?
  capacity       Int
  ticketPrice    Int           @map("ticket_price")
  images         String[]      @default([])
  category       EventCategory @default(dining)
  status         EventStatus   @default(draft)
  isFeatured     Boolean       @default(false) @map("is_featured")
  bundleDiscount Int           @default(0) @map("bundle_discount")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  vendor         Vendor        @relation(fields: [vendorId], references: [id])
  bundles        EventBundle[]
  tickets        EventTicket[]

  @@index([vendorId])
  @@index([date])
  @@index([status])
  @@map("events")
}

model EventTicket {
  id          String            @id @default(uuid())
  eventId     String            @map("event_id")
  userId      String            @map("user_id")
  quantity    Int               @default(1)
  totalCredits Int              @map("total_credits")
  status      EventTicketStatus @default(pending)
  qrCode      String?           @map("qr_code")
  checkedInAt DateTime?         @map("checked_in_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  event       Event             @relation(fields: [eventId], references: [id])
  user        User              @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
  @@map("event_tickets")
}

model EventBundle {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  eventId        String       @map("event_id")
  reservationId  String?      @unique @map("reservation_id")
  totalCredits   Int          @map("total_credits")
  depositCredits Int          @map("deposit_credits")
  bonusCredits   Int          @default(0) @map("bonus_credits")
  status         BundleStatus @default(pending)
  qrCode         String?      @map("qr_code")
  checkedInAt    DateTime?    @map("checked_in_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  event          Event        @relation(fields: [eventId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  reservation    Reservation? @relation(fields: [reservationId], references: [id])

  @@index([eventId])
  @@index([userId])
  @@map("event_bundles")
}

// ============================================================================
// FEATURED
// ============================================================================

model FeaturedPackage {
  id            String         @id @default(uuid())
  name          String
  type          FeaturedType
  description   String?
  creditsCost   Int            @map("credits_cost")
  durationDays  Int            @map("duration_days")
  isActive      Boolean        @default(true) @map("is_active")
  sortOrder     Int            @default(0) @map("sort_order")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  featuredSpots FeaturedSpot[]

  @@map("featured_packages")
}

model FeaturedSpot {
  id           String          @id @default(uuid())
  vendorId     String          @map("vendor_id")
  packageId    String          @map("package_id")
  type         FeaturedType
  experienceId String?         @map("experience_id")
  offerId      String?         @map("offer_id")
  creditsPaid  Int             @map("credits_paid")
  startDate    DateTime        @map("start_date")
  endDate      DateTime        @map("end_date")
  isActive     Boolean         @default(true) @map("is_active")
  addedByAdmin Boolean         @default(false) @map("added_by_admin")
  adminId      String?         @map("admin_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  vendor       Vendor          @relation(fields: [vendorId], references: [id])
  package      FeaturedPackage @relation(fields: [packageId], references: [id])

  @@index([vendorId])
  @@index([type])
  @@index([startDate, endDate])
  @@index([isActive])
  @@map("featured_spots")
}

